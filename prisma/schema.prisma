generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  decks      Deck[]
  flashcards FlashCard[]
  progress   FlashCardProgress[]
  history    ReviewHistory[]
}

model Deck {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  isPublic  Boolean  @default(false)
  sourceDeckId Int?
  questionLanguage String?
  answerLanguage   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  sourceDeck    Deck?       @relation("DeckSource", fields: [sourceDeckId], references: [id], onDelete: SetNull)
  importedDecks Deck[]      @relation("DeckSource")
  flashcards    FlashCard[]

  @@unique([userId, name])
  @@unique([userId, sourceDeckId])
}

model FlashCard {
  id          Int      @id @default(autoincrement())
  userId      Int
  deckId      Int
  sourceCardId Int?
  question    String
  answer      String
  description String?
  createdAt   DateTime @default(now())

  user         User                @relation(fields: [userId], references: [id])
  deck         Deck                @relation(fields: [deckId], references: [id])
  sourceCard   FlashCard?          @relation("FlashCardOverride", fields: [sourceCardId], references: [id], onDelete: SetNull)
  overriddenBy FlashCard[]         @relation("FlashCardOverride")
  progress     FlashCardProgress[]
  history      ReviewHistory[]

  @@unique([deckId, sourceCardId])
}

model FlashCardProgress {
  id           Int       @id @default(autoincrement())
  userId       Int
  cardId       Int
  correctCount Int       @default(0)
  wrongCount   Int       @default(0)
  reviewCount  Int       @default(0)
  nextReview   DateTime?
  lastReviewed DateTime?

  user User      @relation(fields: [userId], references: [id])
  card FlashCard @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
}

model ReviewHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  cardId    Int
  result    Boolean
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  card FlashCard @relation(fields: [cardId], references: [id])
}
